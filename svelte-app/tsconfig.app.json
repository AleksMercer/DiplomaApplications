{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "types": ["svelte", "vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "../shared/**/*.ts",
    "../shared/**/*.d.ts"
  ]
}
